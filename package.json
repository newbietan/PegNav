{
  "name": "pegnav",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "build": "vite build",
    "deploy": "npm run build && wrangler deploy",
    "db:local": "wrangler d1 execute personal-nav-db --local --file=./schema.sql",
    "db:remote": "wrangler d1 execute personal-nav-db --remote --file=./schema.sql",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json"
  },
  "dependencies": {
    "hono": "^4.7.10"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wrangler": "^4.16.0"
  }
}
